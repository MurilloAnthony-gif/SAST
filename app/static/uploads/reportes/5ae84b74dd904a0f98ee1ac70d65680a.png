escription":3592,"created":30398,"ordering":30399},"https://cdn.modrinth.com/data/T4GhhQve/images/992ee1480f37c132e40b799f0ca73c5d0239f6e4_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/992ee1480f37c132e40b799f0ca73c5d0239f6e4.png","2026-04-07T16:48:16.170687Z",16,{"url":30401,"raw_url":30402,"featured":439,"title":3592,"description":3592,"created":30403,"ordering":30404},"https://cdn.modrinth.com/data/T4GhhQve/images/6217a41a8f03193a356600b2d3973235f255da52_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/6217a41a8f03193a356600b2d3973235f255da52.png","2026-04-07T16:45:15.997037Z",17,{"url":30406,"raw_url":30407,"featured":439,"title":3592,"description":3592,"created":30408,"ordering":30409},"https://cdn.modrinth.com/data/T4GhhQve/images/753fe8d7719025cce444836e39e6bc3220e9ba09_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/753fe8d7719025cce444836e39e6bc3220e9ba09.png","2026-04-07T16:45:28.115345Z",18,2305050,"HqhzEFw4",{"client_side":29950,"server_side":29950,"game_versions":30413,"id":30414,"slug":30415,"project_type":31,"team":30416,"organization":3592,"title":30417,"description":30418,"body":30419,"body_url":3592,"published":30420,"updated":30421,"approved":30422,"queued":30423,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30424,"downloads":30425,"followers":30346,"categories":30426,"additional_categories":30427,"loaders":30428,"versions":30429,"icon_url":30431,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30432,"gallery":30435,"color":30489,"thread_id":30490,"monetization_status":30002},[1469,1271,1136,1043],"T3x4fzmb","not-enough-weapons","e0xWNoMP","Not Enough Weapons","This mod adds 8 new weapon types to the game with bonus attributes and effects based on its name.","#### This mod adds 8 new weapon types to the game for every default minecraft tool material. \n\n(Wood, stone, gold, iron, diamond, netherite)\n\n\"club\"\n\n\"large club\"\n\n\"dagger\"\n\n\"glaive\"\n\n\"greatsword\"\n\n\"hammer\"\n\n\"longhammer\"\n\n\"short sword\"\n\n \n\nSo a total of 48 new items.\n\n \n\nAfter crafting the item it will get a unique name that will change the power of the weapon.\nCurrently there are 62 unique names to choose from.\n\n \n\n#### Attribute and effect bonus:\n\ndamage, attack speed, attack knockback, armor, armor toughness, knockback resistance, movement speed, On-Hit Effects (aqua color) and Passive Effects (dark aqua color)\n\n \n\nThe values for these can be changed in the ydmscorex config file.\n\n \n\nSome effect have summoning or taming effects. (20% on-hit chance)\n\nLike taming spider, zombie, skeleton or summon witch, guard, bat.\n\n \n\n#### IMPORTANT:\n\n#### This mod uses the YDM's coreX Library\n\n#### So dont forget to download it.","2023-09-08T13:00:46.055643Z","2023-09-08T13:19:04.694337Z","2023-09-08T18:23:49.525574Z","2023-09-08T13:24:51.527681Z",{"id":30051,"name":10,"url":3592},4337,[115,191],[],[354],[30430],"Yelu3tOL","https://cdn.modrinth.com/data/T3x4fzmb/e76eb30622d5e64c7d9f7f0730ca096211c9cf56_96.webp",[30433],{"id":3137,"platform":3138,"url":30434},"https://www.patreon.com/yourdailymodder",[30436,30441,30446,30451,30456,30461,30464,30469,30474,30479,30484],{"url":30437,"raw_url":30438,"featured":439,"title":30439,"description":3592,"created":30440,"ordering":30075},"https://cdn.modrinth.com/data/T3x4fzmb/images/04579c6d99f2ac5b7aed0056ff49ee67e8ef89ad_350.webp","https://cdn.modrinth.com/data/T3x4fzmb/images/04579c6d99f2ac5b7aed0056ff49ee67e8ef89ad.png","longhammer","2023-09-08T13:08:38.745680Z",{"url":30442,"raw_url":30443,"featured":439,"title":30444,"description":3592,"created":30445,"ordering":30075},"https://cdn.modrinth.com/data/T3x4fzmb/images/1199415ab7cc5c91d38647472980fc3a772b7449_350.webp","https://cdn.modrinth.com/data/T3x4fzmb/images/1199415ab7cc5c91d38647472980fc3a772b7449.png","short sword","2023-09-08T13:08:09.899637Z",{"url":30447,"raw_url":30448,"featured":439,"title":30449,"descr