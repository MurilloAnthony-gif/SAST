31801,31850,31878,31908,31962,32063,32098,32167,32205,32250,32300,32334,32405,32453,32477,32512,32604,32634],{"client_side":29949,"server_side":29950,"game_versions":29951,"id":29952,"slug":29953,"project_type":31,"team":29954,"organization":3592,"title":29955,"description":29956,"body":29957,"body_url":3592,"published":29958,"updated":29959,"approved":29960,"queued":29961,"status":29937,"requested_status":29939,"moderator_message":3592,"license":29962,"downloads":29965,"followers":29966,"categories":29967,"additional_categories":29968,"loaders":29969,"versions":29970,"icon_url":29973,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":29974,"gallery":29975,"color":30000,"thread_id":30001,"monetization_status":30002},"optional","required",[884],"T4MJnkNT","cauldron-brewing","NoIOWE1e","Cauldron Brewing","Simple datapack allowing you to brew potions in a cauldron.","![Title Text](https://cdn.modrinth.com/data/cached_images/34ef56eee68d23897891cc4100198dba61af3c16.png)\n## **Datapack for Minecraft Java Edition 1.20.6**\n# **Cauldron Brewing**\n![Title image showing off all the different potion colors in cauldrons](https://cdn.modrinth.com/data/cached_images/303927ec1db1b1a4408f21f7e2fe8b1032904ae2.png)\nAllows you to brew all potions using a cauldron instead of a brewing stand.\nCurrently only available for 1.20.6\n## Usage\n![A set of cauldrons for all supported heat sources.](https://cdn.modrinth.com/data/cached_images/3f9405333e45c6267be730c3a1de5329948ed412.png)\nPlace a cauldron over a heat source. (e.g. Fire, Campfire, Magma)\n\nDrop any ingredient you would use in a brewing stand in the water.\n\n![A Cauldron in a witches hut containing a strength potion.](https://cdn.modrinth.com/data/cached_images/f307c915d0de57a6c336766e3730cb85e7040c7a.png)\nHold a bottle in your hand to see what the cauldron contains.\n\nUse a bottle on the cauldron to fill it with the potion.\n## Installation\n1. Drop \"CauldronBrewing(resourcepack)\" in your resourcepack folder\n2. Drop \"CauldronBrewing(datapack)\" in your worlds datapacks folder","2024-05-21T16:31:14.331306Z","2024-05-24T10:24:49.456880Z","2024-05-24T06:23:45.803112Z","2024-05-23T15:19:26.368743Z",{"id":29963,"name":29964,"url":3592},"MIT","MIT License",741,11,[100,303],[134,171],[342,346,354,409],[29971,29972],"8LUQGmof","jr9oHPTO","https://cdn.modrinth.com/data/T4MJnkNT/9f2cdc49b4c6896207774f6ba283bd7866ae86b3_96.webp",[],[29976,29982,29988,29994],{"url":29977,"raw_url":29978,"featured":439,"title":29979,"description":3592,"created":29980,"ordering":29981},"https://cdn.modrinth.com/data/T4MJnkNT/images/34ef56eee68d23897891cc4100198dba61af3c16_350.webp","https://cdn.modrinth.com/data/T4MJnkNT/images/34ef56eee68d23897891cc4100198dba61af3c16.png","Title Text","2024-05-21T17:16:49.324669Z",1,{"url":29983,"raw_url":29984,"featured":849,"title":29985,"description":3592,"created":29986,"ordering":29987},"https://cdn.modrinth.com/data/T4MJnkNT/images/0cc2e23715122205a8a060834e3f97e0de36ade0_350.webp","https://cdn.modrinth.com/data/T4MJnkNT/images/303927ec1db1b1a4408f21f7e2fe8b1032904ae2.png","Title Image","2024-05-22T12:18:03.446542Z",2,{"url":29989,"raw_url":29990,"featured":439,"title":29991,"description":3592,"created":29992,"ordering":29993},"https://cdn.modrinth.com/data/T4MJnkNT/images/3f9405333e45c6267be730c3a1de5329948ed412_350.webp","https://cdn.modrinth.com/data/T4MJnkNT/images/3f9405333e45c6267be730c3a1de5329948ed412.png","All heat sources","2024-05-21T17:18:16.123857Z",3,{"url":29995,"raw_url":29996,"featured":439,"title":29997,"description":3592,"created":29998,"ordering":29999},"https://cdn.modrinth.com/data/T4MJnkNT/images/f307c915d0de57a6c336766e3730cb85e7040c7a_350.webp","https://cdn.modrinth.com/data/T4MJnkNT/images/f307c915d0de57a6c336766e3730cb85e7040c7a.png","Preview in a swamp hut","2024-05-21T17:18:48.982849Z",4,6644316,"WpFeTBAB","monetized",{"client_side":29950,"server_side":29950,"game_versions":30004,"id":30005,"slug":30006,"project_type":34,"team":30007,"organization":3592,"title":30008,"description":30009,"body":30010,"body_url":3592,"published":30011,"updated":30012,"approved":30013,"queued":30014,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30015,"downloads":30017,"followers":29981,"categories":30018,"additional_categories":30019,"loaders":30020,"versions":30021,"icon_url":30026,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30027,"gallery":30028,"color":30034,"thread_id":30035,"monetization_status":30002},[841],"T3MIrf2F","friendscraft-2","gpbzsEQO","FriendsCraft 2","This is a modpack perfectly designed for just having fun with your friends on an server!","![This is the logo of FriendsCraft 2.](https://cdn.modrinth.com/data/cached_images/685610b3ce423d77dde28da1ddcef4bfe5ee5af8.png)\n\nFriendsCraft 2\n-----------------\nDo you want to have a great adventure with your friends in Minecraft without the game being filled with hundreds of mods? Then this modpack is exactly right for you!\nThis modpack is aimed at keeping Minecraft mostly vanilla, but it adds some quality of life features, as well as improving and making the boss fights more difficult, making the adventure more exciting! \n\n_Friends are not included!_\n\nVersions\n-----------------\nThere are 4 versions of the modpack:\n- **Standard**: This version is intended for players who only want to join a server with this modpack. All mods that are only needed on the server side are not included in this modpack.\n- **Low Performance**: Like the client version, this version is intended for players who want to join a server with this modpack. However, this version is only suitable for players who do not have a powerful computer, as most of the mods to improve the game's graphics have been removed in this version.\n\nFeatures\n-----------------\nThis modpack contains many functions and mods. Here are the most important ones:\n- Thanks to many performance mods, the game should run smoothly and you can also use shaders.\n- With the help of **Simple Voice Chat**, you can talk to other players in-game and thus interact better with each other.\n- With **NoEmotecraft**, you can use emotes.\n- Now you can harvest faster with **RightClickHarvest** by simply right-clicking your crops. Tip: With a hoe you can harvest several crops at the same time.\n- Build a simple and efficient shop where your friends can buy something with the help of **Universal Shops**.\n- Create amazing armor stands with special poses through **Armor Poser**.\n- Sit on all possible stairs just by right-clicking them using the **Sit!** mod.\n- So that you are no longer easily killed by your friends, you can use **Defense** to activate a shield with which your friends can no longer attack you, but you can no longer attack them either.\n- **Enderpack** gives you the opportunity to always have an Enderchest on your back.\n- With **Genshin Instruments**, you can introduce your friends to your great music in Minecraft.\n- With **Camerapture**, you can record the most important moments with a camera and then hang these pictures on the wall anywhere, e.g. on your friend's wall.\n- Craft an invisible item frame using **Invis item frame**.\n- You die? No problem, because with **Hardcore Revival**, your friends can revive you as long as they are with you.\n- Your friends don't want to save you and you really die? Then **You're in Grave Danger** is just right for you, which spawns a grave with all your items at your death point.\n- Store your XP in bottles with **Bottle Your Xp**, but be careful: when you use it you don't get the same amount of XP back!\n- Combine your elytra and your chestplate with the help of **Armored Elytra**.\n- Your elytra can now look as beautiful as your chestplate with **Elytra Trims**.\n- Do you have to protect your chests from your friends? Now you can lock them, your chests and not your friends, with a trial key.\n- Now you can store 4 of your tools in your belt with **Utility Belt** and not fill your hotbar unnecessarily.\n- Exploring is now much more exciting, as **Tectonic** makes world generation more complicated and exciting.\n- The Wither is too easy for you? With the help of **Withering Heights: Revamped Wither**, the Wither fight becomes much more difficult.\n- Getting to the End is now also more difficult, as **End Remastered** adds new special Ender eyes that can spawn in all kinds of structures. (The Wither also drops one)\n- **True Ending: Ender Dragon Overhaul** makes the Ender Dragon fight much more difficult with new attacks.\n- After you have defeated the Ender Dragon, you can explore the new structures in the End through **Medieval Buildings [End Edition]**.\n- Includes [Stay True Texture Pack](https://www.9minecraft.net/stay-true-resource-pack/)\n- Includes [Vanilla Tweaks Texture Pack](https://vanillatweaks.net/picker/resource-packs/)\n- And much more...","2024-09-27T17:11:21.277476Z","2024-10-03T15:00:18.881142Z","2024-10-08T06:12:32.158486Z","2024-10-06T06:39:55.681072Z",{"id":29963,"name":29964,"url":30016},"https://www.wikiwand.com/de/articles/MIT-Lizenz",317,[30,200,211],[69,162],[346],[30022,30023,30024,30025],"GABvEp38","gmVhdAya","SJ6FFQJm","8aiQ3l18","https://cdn.modrinth.com/data/T3MIrf2F/a4656e09e779d1e23cfff0dbf3d6927e69c95476_96.webp",[],[30029],{"url":30030,"raw_url":30031,"featured":849,"title":30032,"description":3592,"created":30033,"ordering":29981},"https://cdn.modrinth.com/data/T3MIrf2F/images/6cb77bf2d3804af8ad02f7425c846341b1c39781_350.webp","https://cdn.modrinth.com/data/T3MIrf2F/images/6cb77bf2d3804af8ad02f7425c846341b1c39781.png","FriendsCraft 2 - Splashscreen","2024-09-27T20:34:51.901965Z",1315860,"oNGk5OuP",{"client_side":29950,"server_side":30037,"game_versions":30038,"id":30039,"slug":30040,"project_type":31,"team":30041,"organization":30042,"title":30043,"description":30044,"body":30045,"body_url":3592,"published":30046,"updated":30047,"approved":30048,"queued":30049,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30050,"downloads":30052,"followers":30053,"categories":30054,"additional_categories":30055,"loaders":30056,"versions":30057,"icon_url":30066,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":30067,"donation_urls":30068,"gallery":30069,"color":30076,"thread_id":30077,"monetization_status":30002},"unsupported",[1394,1376,1313,1298,1271,1214,1181,1172,1136,1097,1049,1043,1010,968,962,890,884,847,841,793,790,760,712],"T3yEYSUT","luna","dp8Ig9TT","hPbEqJ6D","Luna","Core mod for all Luna Pixel Studios modpacks.","[![This is an image](https://i.imgur.com/eCqrFBC.jpeg)](https://www.discord.gg/LunaPixel)\n\n[1]:\nhttps://cdn.discordapp.com/attachments/1148115823970492467/1148115879599542272/Background.jpg\n\n[2]:\nhttps://www.discord.gg/9S5tfrY4Fr \n\n### Luna \n\nThe core mod of Luna Pixel Studios' modpacks. This mod adds resources and features needed in all of our packs, including world sharing.\n\nThis mod was solely made to be used in LPS modpacks so it isn't guaranteed to work outside them.\n\n\n\u003Cdetails>\n\u003Csummary>License & Privacy Policy\u003C/summary>\n\n## License\nCopyright (C) 2025 Luna Pixel Studios\nAll rights reserved unless explicitly stated.\n\nThe project is provided \"as is\", without warranty of any kind, express or implied, including but not limited to the warranties of merchantability, fitness for a particular purpose and noninfringement. In no event shall the author or copyright holders be liable for any claim, damages or other liability, whether in an action of contract, tort or otherwise, arising from, out of or in connection with the project or the use or other dealings in the project.\n\n## Privacy Policy\nLast Change: January 25th 2025\n\nLuna Pixel Studios (\"we,\" \"our,\" or \"us\") provides a free reverse proxy service called Luna World Sharing to users while prioritizing privacy and security. This Privacy Policy outlines how we handle data transmitted through our service.\n\n## Data Collection\nWhen using our reverse proxy service, certain data is transmitted to our servers to ensure proper functionality and security.\n\n**Data collection begins when you:**\n- Use the \"Share World\" or \"Open to LAN\" button in the game menu.\n- Execute the /luna start command in Minecraft.\n\n**The collected data includes, but is not limited to:**\n- IP Addresses: Collected temporarily to process requests and safeguard the service.\n- UUID (Universally Unique Identifier): Collected to distinguish the user's Minecraft Account UUID.\n- Network Data (Packets) from the Minecraft Integrated Server.\n\n**We use the collected data for the following purposes:**\n- To provide players with a way to create temporary servers to play with other players without the need of opening ports or creating a server, using reverse-proxy technology.\n- To protect our systems by detecting and mitigating potential abuse, spam, or malicious activity.\nIP addresses and UUIDs may be cross-checked against databases of known spam or malicious activity sources. If a match is found, the connection may be automatically blocked to maintain the integrity of our services.\n\n## Data Storage\nWe do not store any data collected during your use of our services. All information, including IP addresses, UUIDs and network data, is processed in real-time and discarded immediately after its intended use.\n\n## Third-Party Services\nWe do not share your data with third-party services unless required by law or to comply with applicable regulations.\n\n## Your Rights\nSince we do not store any user data, there is no information retained that can be accessed, modified, or deleted.\n\n## Changes to This Policy\nWe reserve the right to update this Privacy Policy as necessary to reflect changes to our practices or legal requirements. Updates will be posted with a revised effective date.\n\n\u003C/details>\n\n","2023-09-17T09:00:16.705604Z","2025-06-03T14:59:53.081761Z","2023-09-18T21:08:53.352721Z","2023-09-17T09:14:18.477119Z",{"id":30051,"name":10,"url":3592},"LicenseRef-All-Rights-Reserved",4092194,73,[157],[175],[346,354,385],[30058,30059,30060,30061,30062,30063,30064,30065],"JdfDvtJ7","QTQnGYRR","lJsS1j7C","XTvbSFNh","J72toqtI","iHTZJ3YI","oVGNuhFY","PueyP1Ml","https://cdn.modrinth.com/data/T3yEYSUT/df79d648c88dce48b1d0e57112b108de7a9b8a6c_96.webp","https://ww.discord.gg/9S5tfrY4Fr",[],[30070],{"url":30071,"raw_url":30072,"featured":849,"title":30073,"description":3592,"created":30074,"ordering":30075},"https://cdn.modrinth.com/data/T3yEYSUT/images/a4871abc2590dc9f8df685a7b875cf42b22620b4_350.webp","https://cdn.modrinth.com/data/T3yEYSUT/images/91a12d7679232b9d2fe0a5706939d6b62961667c.png","World Sharing","2023-09-17T09:14:02.865086Z",0,1983381,"pMXoIBs2",{"client_side":29949,"server_side":29950,"game_versions":30079,"id":30080,"slug":30081,"project_type":31,"team":30082,"organization":3592,"title":30083,"description":30084,"body":30085,"body_url":3592,"published":30086,"updated":30087,"approved":30088,"queued":30089,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30090,"downloads":30094,"followers":30095,"categories":30096,"additional_categories":30097,"loaders":30098,"versions":30099,"icon_url":30108,"issues_url":3592,"source_url":30109,"wiki_url":3592,"discord_url":30110,"donation_urls":30111,"gallery":30117,"color":30135,"thread_id":30136,"monetization_status":30002},[847,841,793,790,760,712,670,661,655,610,604,559,505,499,487],"T3Zgylk8","meteors","7CKVCoCy","Meteors","Meteors falls from the sky!","# Meteors\n\n[![Discord](https://img.shields.io/discord/1327308441324097681?label=discord&color=blue&logo=discord)](https://discord.gg/5UdcDa5xNC)\n[![Modrinth](https://img.shields.io/modrinth/dt/meteors?label=modrinth&logo=modrinth)](https://modrinth.com/datapack/meteors)\n[![License](https://img.shields.io/github/license/lullaby6/data-packs)](https://github.com/lullaby6/data-packs/blob/main/LICENSE)\n\n\u003Chr>\n\n## 📖 Description\n\nA new challenge to your world. At unpredictable intervals, a meteorite falls from the sky, and you'll hear a distinctive sound as it approaches, building anticipation and tension.\n\n\u003Chr>\n\n## ⌨️ Commands\n\nSpawn meteor:\n\n```mcfunction\n/function meteors:meteor/spawn\n```\n\nConfig (1.21.6+):\n\n```mcfunction\n/function meteors:config\n```\n\n\u003Chr>\n\n## 🪪 License\n\n[AGPL-3.0-or-later](https://github.com/lullaby6/data-packs/blob/main/LICENSE)\n\n\u003Chr>\n\n## 👾 Bugs/Issues\n\nPlease report any problem/bug/issues in the [Discord Server](https://discord.gg/5UdcDa5xNC).\n\n\u003Chr>\n\n## 💌 Donate\n\n- [Donate on Ko-Fi](https://ko-fi.com/lullaby45743)\n- [Donate on PayPal](https://www.paypal.com/paypalme/lucianobrumer)\n\n\u003Chr>\n\n## 🎁 Server Hosting\n\nCreating your own server can be a very lengthy, tedious and costly process.\n\nBut with BisectHosting, you get your own server in just a couple of clicks! With their 24/7 support and fast-response time, no issues shall stand in your way!\nInterested? Then we've got a deal for you!\n\nhttps://bisecthosting.com/lullaby\n\n![Server Hosting](https://www.bisecthosting.com/partners/custom-banners/e840cd99-59f6-4b27-b542-3023cd08bdfe.webp)","2025-03-03T22:35:39.945670Z","2025-10-01T18:02:47.842601Z","2025-03-06T05:48:39.794718Z","2025-03-03T22:42:44.820833Z",{"id":30091,"name":30092,"url":30093},"AGPL-3.0-or-later","GNU Affero General Public License v3.0 or later","https://github.com/lullaby6/data-packs/blob/main/LICENSE",8263,51,[30,134],[93,316],[342,346,354,385,409],[30100,30101,30102,30103,30104,30105,30106,30107],"ETLVNS0d","jogadZRd","I7tbijav","XZYF1opi","ugD356g7","mTeaZHIs","cGzSAqcz","aHYpxFDj","https://cdn.modrinth.com/data/T3Zgylk8/2a7ef4cff3de41377543534c24e91362f6db404a_96.webp","https://github.com/lullaby6/data-packs/tree/main/Meteors","https://discord.gg/5UdcDa5xNC",[30112,30115],{"id":3143,"platform":30113,"url":30114},"Paypal","https://paypal.me/lucianobrumer",{"id":3149,"platform":3150,"url":30116},"https://ko-fi.com/lullaby45743",[30118,30123,30127,30131],{"url":30119,"raw_url":30120,"featured":849,"title":30121,"description":3592,"created":30122,"ordering":30075},"https://cdn.modrinth.com/data/T3Zgylk8/images/b3eee84a0592d004884c77244e8bcc4e39f339a7_350.webp","https://cdn.modrinth.com/data/T3Zgylk8/images/b3eee84a0592d004884c77244e8bcc4e39f339a7.png","Explosion","2025-03-03T22:38:57.405553Z",{"url":30124,"raw_url":30125,"featured":439,"title":3592,"description":3592,"created":30126,"ordering":29981},"https://cdn.modrinth.com/data/T3Zgylk8/images/70ba8e06b6b145a8257803da40132ca632773f30_350.webp","https://cdn.modrinth.com/data/T3Zgylk8/images/70ba8e06b6b145a8257803da40132ca632773f30.png","2025-03-03T22:39:06.522124Z",{"url":30128,"raw_url":30129,"featured":439,"title":3592,"description":3592,"created":30130,"ordering":29987},"https://cdn.modrinth.com/data/T3Zgylk8/images/60cceb0f2f0ad2ef07a924186602818af116f7e4_350.webp","https://cdn.modrinth.com/data/T3Zgylk8/images/60cceb0f2f0ad2ef07a924186602818af116f7e4.png","2025-03-03T22:39:24.285996Z",{"url":30132,"raw_url":30133,"featured":439,"title":3592,"description":3592,"created":30134,"ordering":29999},"https://cdn.modrinth.com/data/T3Zgylk8/images/b0d17b4500587873ecdd9b77b19c16db8eaa0f1e_350.webp","https://cdn.modrinth.com/data/T3Zgylk8/images/b0d17b4500587873ecdd9b77b19c16db8eaa0f1e.png","2025-07-31T17:56:38.175256Z",1708054,"dHQQJX8R",{"client_side":30037,"server_side":29950,"game_versions":30138,"id":30139,"slug":30140,"project_type":31,"team":30141,"organization":3592,"title":30142,"description":30143,"body":30144,"body_url":3592,"published":30145,"updated":30146,"approved":30147,"queued":30148,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30149,"downloads":30151,"followers":30075,"categories":30152,"additional_categories":30153,"loaders":30154,"versions":30155,"icon_url":30157,"issues_url":30158,"source_url":30159,"wiki_url":3592,"discord_url":3592,"donation_urls":30160,"gallery":30161,"color":30162,"thread_id":30163,"monetization_status":30002},[655],"T39vHqGB","deathrun-minigame","zv0UzOf6","Deathrun","Deathrun minigame — sprint in one direction, every heart lost is permanent, player with highest distance wins.","# Deathrun\n\nAll players start inside a glass cage. When the countdown ends the cage opens and everyone sprints in the configured direction. **Every heart lost is permanent** — no regeneration. A per-player WorldBorder follows each runner and deals damage outside the corridor. The player who travels the furthest wins.\n\n## Features\n- 🏃 Run direction: North / South / East / West\n- ❤ Permanent health loss, no regeneration\n- 📦 Glass cage with terrain snapshot & restore\n- 📊 Live scoreboard — top 5, rank, distance, timer\n- 💗 Tab list with color-coded heart display (♥♡)\n- ⚔ PvP system with configurable delay & countdown\n- ⏸ Full pause mode (freezes everything)\n- 🌍 19 languages, per-player auto-detection\n- 🔔 Title screens & sounds for start, end and PvP activation\n\n## Requirements\n- Paper 1.21.8\n- Java 21\n\n## Setup\n1. Place the JAR in `plugins/`\n2. Start the server (maintenance mode, OPs only)\n3. Stand at the desired cage spot → `/dr buildcage`\n4. `/dr open` → players can join\n5. `/dr start` → countdown begins\n\n## Commands\n\n| Command | Description |\n|-|-|\n| `/dr buildcage` | Build cage at your position |\n| `/dr removecage` | Remove cage & restore terrain |\n| `/dr open` / `/dr close` | Open or lock the server |\n| `/dr start` / `/dr stop` | Start or reset the game |\n| `/dr pause` | Pause / resume |\n| `/dr setdirection \u003Cdir>` | Sets run direction: NORTH / SOUTH / EAST / WEST |\n| `/dr setcorridor \u003Cn>` | Corridor half-width in blocks |\n| `/dr status` | Show current config |","2026-04-07T18:07:11.347269Z","2026-04-07T18:11:32.376325Z","2026-04-11T22:12:25.804199Z","2026-04-07T18:17:45.460217Z",{"id":29963,"name":29964,"url":30150},"https://github.com/flyingfinger1/deathrun/blob/main/LICENSE",20,[185],[],[401],[30156],"QHChRDip","https://cdn.modrinth.com/data/T39vHqGB/09e08303f272d7639bb1dc07d1771ab29e09b4fd_96.webp","https://github.com/flyingfinger1/deathrun/issues","https://github.com/flyingfinger1/deathrun",[],[],14100783,"x9z3lujp",{"client_side":29950,"server_side":29950,"game_versions":30165,"id":30166,"slug":30167,"project_type":34,"team":30168,"organization":3592,"title":30169,"description":30170,"body":30171,"body_url":3592,"published":30172,"updated":30173,"approved":30174,"queued":30175,"status":29937,"requested_status":29939,"moderator_message":3592,"license":30176,"downloads":30177,"followers":30075,"categories":30178,"additional_categories":30179,"loaders":30180,"versions":30181,"icon_url":30190,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":30191,"donation_urls":30192,"gallery":30193,"color":30198,"thread_id":30199,"monetization_status":30002},[1043],"T3FOaFC4","danisbasementmodpack","j7HtALWQ","Dani's Basement","A vanilla+ pack built for Dani's Basement server.","Dani's Basement is a vanilla+ modpack designed for the Dani's Basement Minecraft server. It includes over 100 mods that expand on the base game without straying far from its core mechanics.\n\nThe pack focuses on technology, automation and exploration. For example, with Create, you can design complex machines and contraptions. With ComputerCraft you can program turtles to automate things, and with Valkyrien Skies you can build and pilot flying ships using physics-based flight.\n\nIt also includes client-side improvements such as performance improvements, inventory sorting and zooming. This pack is required to join the official server but can also be played in singleplayer or on other servers.","2025-05-01T16:28:56.698374Z","2025-06-16T12:13:59.987160Z","2025-05-12T18:59:00.379702Z","2025-05-05T15:27:20.786113Z",{"id":29963,"name":29964,"url":3592},239,[30,200,211],[153,288],[346],[30182,30183,30184,30185,30186,30187,30188,30189],"bqfmqjZx","3poF48AS","BUSbVjN9","9GnvofOL","plCeM4KO","e3ivcofv","VVcKY4ZF","p1dVYmVN","https://cdn.modrinth.com/data/T3FOaFC4/66fb76a4b4b9886191f3da226e97df3669e21ab1_96.webp","https://www.discord.gg/danii",[],[30194],{"url":30195,"raw_url":30196,"featured":849,"title":3592,"description":3592,"created":30197,"ordering":30075},"https://cdn.modrinth.com/data/T3FOaFC4/images/884c7958bb6985610ecc793b40bbe24205f8feb6_350.webp","https://cdn.modrinth.com/data/T3FOaFC4/images/884c7958bb6985610ecc793b40bbe24205f8feb6.png","2025-06-15T18:31:30.506235Z",2696747,"xZylkTzc",{"client_side":29950,"server_side":29949,"game_versions":30201,"id":30202,"slug":30203,"project_type":31,"team":30204,"organization":3592,"title":30205,"description":30206,"body":30207,"body_url":3592,"published":30208,"updated":30209,"approved":30210,"queued":30211,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30212,"downloads":30213,"followers":29987,"categories":30214,"additional_categories":30215,"loaders":30216,"versions":30217,"icon_url":30219,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30220,"gallery":30221,"color":30222,"thread_id":30223,"monetization_status":30002},[841,793,790,760],"T2wO364d","simpleautototem","uMLTf8oA","Simple AutoTotem","Automatically equips Totem of Undying into your offhand slot when available.","# Simple AutoTotem\n\nA Minecraft Fabric mod for 1.21.1+ that automatically equips Totem of Undying items into your offhand slot when available.\n\n## Features\n\n- **Automatic Totem Equipping**: Continuously monitors your inventory and automatically moves Totems of Undying to your offhand slot\n- **Smart Logic**: Only equips totems when your offhand is empty or contains non-shield, non-totem items\n- **Multiplayer Compatible**: Works seamlessly on multiplayer servers with proper client-server synchronization\n- **Configurable**: Toggle the mod on/off with a customizable keybind (default: Y key for QWERTY and Z key for QWERTZ)\n- **Persistent Settings**: Your toggle state is saved between game sessions\n- **Instant Response**: No noticeable delay after a totem is consumed\n\n## Requirements\n\n- Minecraft 1.21.1+\n- Fabric Loader 0.16.5+\n- Fabric API 0.104.0+\n- Java 21+\n\n## Installation\n\n1. Install [Fabric Loader](https://fabricmc.net/use/installer/)\n2. Download [Fabric API](https://modrinth.com/mod/fabric-api)\n3. Place both the Fabric API and AutoTotem mod files in your `mods` folder\n4. Launch Minecraft with the Fabric profile\n\n## Usage\n\n- The mod is enabled by default when you join a world\n- Press **Y** or **Z** (default keybind) to toggle AutoTotem on/off\n- A message will appear in your action bar showing the current state\n- The mod only works in Survival and Adventure game modes\n- Your offhand must be empty or contain a non-shield, non-totem item for automatic equipping\n\n\n## License\n\nThis project is licensed under the MIT License.","2025-08-14T23:46:28.417259Z","2025-08-14T23:55:45.298781Z","2025-08-19T07:08:43.846204Z","2025-08-14T23:56:24.693113Z",{"id":29963,"name":29964,"url":3592},3337,[115,134,211],[30,175,303],[346],[30218],"BWEJg3iW","https://cdn.modrinth.com/data/T2wO364d/91faeb8422b307565da29873f03fd58ef6600ab0_96.webp",[],[],4011312,"kCn5O2IQ",{"client_side":29950,"server_side":30037,"game_versions":30225,"id":30226,"slug":30227,"project_type":12,"team":30228,"organization":3592,"title":30229,"description":30230,"body":30231,"body_url":3592,"published":30232,"updated":30233,"approved":30234,"queued":30235,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30236,"downloads":30237,"followers":30075,"categories":30238,"additional_categories":30239,"loaders":30240,"versions":30241,"icon_url":30243,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30244,"gallery":30245,"color":30249,"thread_id":30250,"monetization_status":30002},[847,841],"T2u06kMJ","more-obvious-trap-chests","l2fB5zbw","More Obvious Trap Chests","makes the trap chests more obvious to notice","This texture pack changes the look of trap chest to male it look more obvious so, you wont get a bad time","2024-12-05T07:38:27.985928Z","2024-12-05T07:42:11.083278Z","2024-12-08T00:24:12.525160Z","2024-12-05T07:43:42.455747Z",{"id":30051,"name":10,"url":3592},236,[57,300],[],[377],[30242],"VaLBINDM","https://cdn.modrinth.com/data/T2u06kMJ/88f74d76ac5dc5a0183038c410d016ea2ef92ce7_96.webp",[],[30246],{"url":30247,"raw_url":30247,"featured":439,"title":3592,"description":3592,"created":30248,"ordering":30075},"https://cdn.modrinth.com/data/T2u06kMJ/images/9dc60ba9ff51f0fc5adddbd1fa8ce6015d861b34.png","2024-12-05T07:43:02.231548Z",5783318,"SV4bGbsU",{"client_side":29950,"server_side":29950,"game_versions":30252,"id":30253,"slug":30254,"project_type":31,"team":30255,"organization":3592,"title":30256,"description":30257,"body":30258,"body_url":3592,"published":30259,"updated":30260,"approved":30261,"queued":30262,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30263,"downloads":30264,"followers":30265,"categories":30266,"additional_categories":30267,"loaders":30268,"versions":30269,"icon_url":30277,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30278,"gallery":30279,"color":30300,"thread_id":30301,"monetization_status":30002},[1271,1172,1097,1043],"T4IvRZqT","feur-colors","C3WWZ0mh","Feur Colors","Add variants of Wool, Terracotta and new color block","![Feur Colors](https://cdn.modrinth.com/data/cached_images/24066fa5321ed31f470ed1df91e9c1dcbbdea7d7.png)\n\nThis is a little project that add :\n\n- Wool Slab\n- Wool Stairs\n- Wool Fence\n- Terracotta Slab\n- Terracotta Stairs\n- Terracotta Wall\n- New type of Glazed Terracotta \n- New type of Wool\n\n\n~ and now new stuff ~\n- Concrete Stairs\n- Concrete Slabs ","2024-09-25T09:04:24.201067Z","2025-01-30T16:18:20.828345Z","2024-09-30T03:35:17.386859Z","2024-09-28T11:02:06.045712Z",{"id":30051,"name":10,"url":3592},3985,10,[100,316],[],[346,354],[30270,30271,30272,30273,30274,30275,30276],"rPDMh3Ac","KTcVqFal","TinfSkgQ","fPSDksn2","FkVIdY2l","xrdafp4d","bNtM7eoL","https://cdn.modrinth.com/data/T4IvRZqT/ed535ef442869ab1fa3c15bfa1bef412a38e6f88_96.webp",[],[30280,30285,30290,30295],{"url":30281,"raw_url":30282,"featured":439,"title":30283,"description":3592,"created":30284,"ordering":30075},"https://cdn.modrinth.com/data/T4IvRZqT/images/6334bb27df75a9e3cdeef2077b06e3d0b0dc8ff3_350.webp","https://cdn.modrinth.com/data/T4IvRZqT/images/6334bb27df75a9e3cdeef2077b06e3d0b0dc8ff3.png","More Terracotta","2024-09-25T09:08:44.931849Z",{"url":30286,"raw_url":30287,"featured":439,"title":30288,"description":3592,"created":30289,"ordering":30075},"https://cdn.modrinth.com/data/T4IvRZqT/images/bcfb8accbd08f24dd1c86c816e29619a3d349767_350.webp","https://cdn.modrinth.com/data/T4IvRZqT/images/bcfb8accbd08f24dd1c86c816e29619a3d349767.png","New Wool","2024-09-25T09:09:21.618722Z",{"url":30291,"raw_url":30292,"featured":849,"title":30293,"description":3592,"created":30294,"ordering":30075},"https://cdn.modrinth.com/data/T4IvRZqT/images/d9c805d77db87c4e29e63428e45fc347086ff101_350.webp","https://cdn.modrinth.com/data/T4IvRZqT/images/d9c805d77db87c4e29e63428e45fc347086ff101.png","New Colors","2024-09-25T09:08:24.008908Z",{"url":30296,"raw_url":30297,"featured":439,"title":30298,"description":3592,"created":30299,"ordering":30075},"https://cdn.modrinth.com/data/T4IvRZqT/images/f85b6da5b7983e72a71b7ca006445d1237c45cc8_350.webp","https://cdn.modrinth.com/data/T4IvRZqT/images/f85b6da5b7983e72a71b7ca006445d1237c45cc8.png","More Wool","2024-09-25T09:08:59.639317Z",3290392,"JjjD4UNE",{"client_side":29950,"server_side":30037,"game_versions":30303,"id":30304,"slug":30305,"project_type":12,"team":30306,"organization":3592,"title":30307,"description":30308,"body":30309,"body_url":3592,"published":30310,"updated":30311,"approved":30312,"queued":30313,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30314,"downloads":30315,"followers":29966,"categories":30316,"additional_categories":30317,"loaders":30318,"versions":30319,"icon_url":30321,"issues_url":3592,"source_url":3592,"wiki_url":3592,"discord_url":3592,"donation_urls":30322,"gallery":30325,"color":30410,"thread_id":30411,"monetization_status":30002},[1049,1043,1040,1037,1034,1031,1028,1010,1001,998,995,992,989,986,968,962,953,950,947,944,941,938,935,932,929,926,923,920,917,914,911,908,905,890,884,881,878,875,872,847,841,838,835,832,829,826,823,820,817,814,811,793,790,787,784,781,760,712,670,661,655,610,604,559,505,499],"T4GhhQve","bushys-wild-expanded","c4honTPK","Bushy's Wild Expanded","Bushier ground flora: enhances leaf litter, petals, and wildflowers with vanilla and mod support, plus configurable options.","![Resourcepack thumbnail](https://cdn.modrinth.com/data/cached_images/1f424abe8ff41ccc913672e9e619a88701df8dc4.png)\n\n**Bushy’s Wild Expanded** enhances ground flora by making elements like leaf litter, petals, and wildflowers denser, fuller, and more immersive. ([Check gallery section!](https://modrinth.com/resourcepack/bushys-wild-expanded/settings/gallery))\n\nIt improves **vanilla features** and **extends support to additional mods**, creating a richer and more natural-looking environment.\n\n**Vanilla includes**:\n - Leaf Litter\n - Pink Petals\n - Wildflowers\n\n**+ Modded support**, including:\n - Biome O’ Plenty (e.g. white petals)\n - Regions Unexplored (e.g. maple leaf litter and more)\n - More coming in future updates\n   - Also supports **Vanilla Backport Mod** for 1.21.1 & 1.20.1. \n\n**Fully configurable (Respackopts support)**:\n\nThis resource pack supports **[Respackopts](https://modrinth.com/mod/respackopts/versions)**, allowing you to customize its features. For example, you can keep pink petals and leaf litter enabled while disabling wildflowers, all directly from the resource pack settings menu.\n\n**Credits & Compatibility**\n- This pack is based on:\n  - Bushy Pink Petals, Wildflowers & Leaf Litter by godhusk\n\nYou do not need these packs separately — **Bushy’s Wild Expanded** includes their vanilla features and expands them with support for popular mods, with more to come in future updates.\n\n> Feel free to use this resource pack in modpacks or personal projects. ♡\n> Please do not reupload this pack on other websites.\nInstead, share the original Modrinth page.","2026-04-07T15:39:43.157867Z","2026-04-07T18:31:23.027878Z","2026-04-08T04:21:41.019869Z","2026-04-07T18:31:29.482537Z",{"id":30051,"name":10,"url":3592},509,[15,57,307],[194],[377],[30320],"8M2aj8ao","https://cdn.modrinth.com/data/T4GhhQve/f2f276a5c3f1e237d2564e583a0f43b1bcb50ff7_96.webp",[30323],{"id":3149,"platform":3150,"url":30324},"https://ko-fi.com/thatscube",[30326,30330,30334,30338,30342,30347,30352,30357,30362,30367,30371,30375,30380,30385,30390,30395,30400,30405],{"url":30327,"raw_url":30328,"featured":849,"title":3592,"description":3592,"created":30329,"ordering":29981},"https://cdn.modrinth.com/data/T4GhhQve/images/e70b4368a2ddbf0ae007a85506243bf456e6a7fe_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/e70b4368a2ddbf0ae007a85506243bf456e6a7fe.png","2026-04-07T16:05:50.219263Z",{"url":30331,"raw_url":30332,"featured":439,"title":3592,"description":3592,"created":30333,"ordering":29987},"https://cdn.modrinth.com/data/T4GhhQve/images/54e788c4b1a72560b9bd3d5018f39dd66f5c96f3_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/54e788c4b1a72560b9bd3d5018f39dd66f5c96f3.png","2026-04-07T16:49:19.899152Z",{"url":30335,"raw_url":30336,"featured":439,"title":3592,"description":3592,"created":30337,"ordering":29993},"https://cdn.modrinth.com/data/T4GhhQve/images/290775db0292fad1dfacb0253b9f7de9c897edca_350.webp","https://cdn.modrinth.com/data/T4GhhQve/images/290775db0292fad1dfacb0253b9f7de9c897edca.png","2026-04-07T16:13:00.866744Z",{"url":30339,"raw_url":30340,"featured":439,"title":3