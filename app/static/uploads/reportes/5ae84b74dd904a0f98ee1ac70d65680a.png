<svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" fill-rule="evenodd" stroke-linecap="round" stroke-linejoin="round" stroke-miterlimit="1.5" clip-rule="evenodd" viewBox="0 0 24 24"><path fill="none" d="M0 0h24v24H0z"></path><path fill="none" stroke="currentColor" stroke-width="2" d="M2 7.5h8v-2h12v2s-7 3.4-7 6 3.1 3.1 3.1 3.1l.9 3.9H5l1-4.1s3.8.1 4-2.9c.2-2.7-6.5-.7-8-6"></path></svg>Forge<!--]--></button><!--]--></div></section><section class="flex flex-col gap-2"><h3 class="text-primary text-base m-0">Supported environments</h3><div class="flex flex-wrap gap-1"><!--[--><div class="bg-[--_bg-color,var(--color-button-bg)] text-nowrap border-[--_bg-color,var(--surface-5)] border-[1px] border-solid px-2 py-1 leading-none rounded-full font-normal text-sm inline-flex items-center gap-1 text-[--_color,var(--color-secondary)] [&amp;&gt;svg]:shrink-0 [&amp;&gt;svg]:h-4 [&amp;&gt;svg]:w-4"><!--[--><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="lucide lucide-monitor-smartphone" viewBox="0 0 24 24"><path d="M18 8V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h8M10 19v-3.96 3.15M7 19h5"></path><rect width="6" height="10" x="16" y="12" rx="2"></rect></svg> Client and server<!--]--></div><!--]--></div></section></div><div class="wrapper relative mb-3 flex w-full justify-center rounded-2xl" data-v-5c9cce00 data-v-bee88a75><a href="/hosting?plan&amp;ref=medal" class="flex max-h-[250px] min-h-[250px] min-w-[300px] max-w-[300px] flex-col gap-4 rounded-[inherit] border border-solid border-surface-4 bg-surface-3" aria-label="Host your next server with Modrinth Hosting" data-v-bee88a75><!--[--><img src="https://cdn-raw.modrinth.com/modrinth-hosting-medal-light.webp" aria-hidden="true" alt="Host your next server with Modrinth Hosting" class="light-image hidden rounded-[inherit]" data-v-bee88a75><img src="https://cdn-raw.modrinth.com/modrinth-hosting-medal-