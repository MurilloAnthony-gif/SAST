0075},"https://cdn.modrinth.com/data/T3x4fzmb/images/93cbd1b7d5672d27927b019e6b887cc5e9a42c22_350.webp","https://cdn.modrinth.com/data/T3x4fzmb/images/93cbd1b7d5672d27927b019e6b887cc5e9a42c22.png","club","2023-09-08T13:08:00.916826Z",{"url":30480,"raw_url":30481,"featured":439,"title":30482,"description":3592,"created":30483,"ordering":30075},"https://cdn.modrinth.com/data/T3x4fzmb/images/cb33193bff4ef574f8264053fef6d479295b3de4_350.webp","https://cdn.modrinth.com/data/T3x4fzmb/images/cb33193bff4ef574f8264053fef6d479295b3de4.png","large club","2023-09-08T13:08:47.629933Z",{"url":30485,"raw_url":30486,"featured":849,"title":30487,"description":3592,"created":30488,"ordering":30075},"https://cdn.modrinth.com/data/T3x4fzmb/images/e76eb30622d5e64c7d9f7f0730ca096211c9cf56_350.webp","https://cdn.modrinth.com/data/T3x4fzmb/images/92b9510b1e3e38f6350efced88543138663ce04a.png","special effects on weapons","2023-09-08T13:07:04.226605Z",2104099,"kB3ICqLR",{"client_side":29950,"server_side":30037,"game_versions":30492,"id":30493,"slug":30494,"project_type":31,"team":30495,"organization":3592,"title":30496,"description":30497,"body":30498,"body_url":3592,"published":30499,"updated":30500,"approved":30501,"queued":30502,"status":29937,"requested_status":29937,"moderator_message":3592,"license":30503,"downloads":30504,"followers":30505,"categories":30506,"additional_categories":30507,"loaders":30508,"versions":30509,"icon_url":30530,"issues_url":30531,"source_url":30532,"wiki_url":3592,"discord_url":30533,"donation_urls":30534,"gallery":30537,"color":30553,"thread_id":30554,"monetization_status":30002},[841,760,712,670,661,655,610,604,559,505,499,487],"T3G2Q24n","litematicdownloader","Tp2x2gHM","LitematicDownloader","Direct schematics downloads for Litematica, fully integrated into your Minecraft client","# Litematic Downloader Mod for Litematica\n\n> [Join our Discord Community](https://discord.choculaterie.com)  \n> [GitHub Repository](https://github.com/Choculaterie/LitematicDownloader) \u003C- Starring it helps me a lot \u003C3\n\n---\n\n## Features\n\n- **In-Game Schematic Browser**  \n  Search and download schematics directly from [choculaterie.com](https://choculaterie.com/), [minemev.com](https://minemev.com/), [mcodex.org](https://mcodex.org) & [redenmc.com](https://redenmc.com/) within Minecraft\n\n- **Schematic File Manager**  \n  Organize, rename, delete, or even change block type directly inside of litematic files and manage them entirely in-game\n\n- **Quick-Share**  \nInstantly share your schematics with friends using a short link! Quick-Share generates a unique URL that opens your schematic in a **[3D web viewer](https://choculaterie.com/litematic-viewer/index.html?Litematic=H4sIAAAAAAAA%2F%2B1dXYwbVxU%2B4xnbY3t%2FnGSbbJI2dZaqLSItcbpJExrCbjZJSWmSJZuUtDRyxvZde8h4xpkZ725CHpzSv0hQopa%2FB0RDeaD8VQVVakFFTauC%2BHugVKIgqBSkCl6qqDxUKjwQ7p0fezwz9s7Y4ySws6tdj2fuPefcc8797jlnrsdJgCTED6ISL4kKPjosilwFFZPAzPCnEA3UKQCI49eFy5cvv49fT5JXSAC7W1R5lUe4E0CEgsRecY5X%2BLyAIApDe1VU2SVL1akyJxbQJ%2BqEC0NOshDhizBc4UVUkLlZ9WOFMlJUGqIFqSaqmBSFfwdIy4OSyqlYKvyePSDeLePrRYgAPcnL1IYUMIcP792F2zM7RmY%2BPPmdifIPv%2FvGoafeOHE%2F6S7O1QQRyRyRhoLoHn4BFbFYA3s4QdjFKyoRCvfFw4jtkwiTGH5DQ5sfXebVTZlLgjSf47GMuVkZawsrwxQ2SpSx8wW9HwWxPVyBF0sMHt8hXkAPkKsJoKclRWN4YTSjNXzlA73DBKO%2FRoDZw8vo8mUahqYlWeWEKUkSitK8CJqcGrH7sSH%2BYxwfwcf%2FAp9GWNUckFKuCceRnFPKSBB6MUbptplX%2Fq3svvRc6vJbP%2F%2FRW3%2B8xo3BdDLG8p6MkYBlOwWpcHwGy4KmOQGpKiJTpcwCsx%2FLCYPNIXC8DObpG5unK1wJiSqXwyrC54q5ksApSqPh8mZDKa8geQ7JSUhOY3sjmcxLFuJVaR7JRNmznKAgFmKzmgaAQZyiQoPSSJOSKKkolydyL0YryYuKKtcqWEJgypxcxdRIb6A2Ninf0KQ8X8Y2Cn4oURGbpOzKMS9wheNtOK6w%2BL5UE3IKh%2F3ZvLiyefFEjZPVU7pGGtfXNq9jkdpwWNXSSFElEeXmsR%2FZBhbVBgZUFvebx0gIjMIX8fh0ExlvolhGPEisX5G804esvXM1YkGqVDmZU6W2WmSw5az%2BQDhjQhWpiCCud7eQtkw2SebEEsoVJLEgI2xss8kap9c62ozaTeNo0dMYiMLajyHdJF2WqlWngyGRAJSLg%2Bm6d%2FNVGVURntw%2BfRW%2FJ95kuR4tIoE7CdQd4OY9%2BVoeC4aVJdQqoo0VU5S5kkGn2XmZRY3kv0NCVjutiWSIkFBlvlRqkTolyTwxpAb7ceIhuVoV3KzZ8G9srULZxosWeFW3VR98lVVqeVXmCmoQhrYhSS%2BgZ