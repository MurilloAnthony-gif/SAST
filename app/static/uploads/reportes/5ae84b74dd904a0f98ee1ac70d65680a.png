PI":849,"labrinthApiCanary":439,"dismissedExternalProjectsInfo":439,"modpackPermissionsPage":439,"showAllBanners":439,"alwaysIgnoreErrorBanner":439,"showViewProdRouteBanner":439,"showModeratorProjectMemberUi":439,"showModeratorPrivateMessageHighlight":849,"archonApiStaging":439,"showHostingAccessInstanceAuditLog":439},["Map"],{"collections":33370,"follows":33371,"subscriptions":33372,"lastUpdated":30075},[],[],[],{"mutations":33374,"queries":33375},[],[33376,33423,33453],{"dehydratedAt":33377,"state":33378,"queryKey":33420,"queryHash":33422},1781741924334,{"data":33379,"dataUpdateCount":29981,"dataUpdatedAt":33417,"error":3592,"errorUpdateCount":30075,"errorUpdatedAt":30075,"fetchFailureCount":30075,"fetchFailureReason":3592,"fetchMeta":3592,"isInvalidated":439,"status":33418,"fetchStatus":33419},{"client_side":29950,"server_side":29950,"game_versions":33380,"id":33381,"slug":33382,"project_type":34,"team":33383,"organization":30042,"title":33384,"description":33385,"body":33386,"body_url":3592,"published":33387,"updated":33388,"approved":33389,"queued":33390,"status":29937,"requested_status":29937,"moderator_message":3592,"license":33391,"downloads":33392,"followers":33393,"categories":33394,"additional_categories":33395,"loaders":33396,"versions":33397,"icon_url":33404,"issues_url":33405,"source_url":3592,"wiki_url":33406,"discord_url":33405,"donation_urls":33407,"gallery":33410,"color":33416,"thread_id":33381,"monetization_status":30002},[1043],"cad6ZNtm","medieval-mc-forge-mmc4","JzaqqFc0","Medieval MC [FORGE] - MMC4","Version 1.20 | Medieval Fantasy RPG Adventure & Exploration Modpack everyone wants!","![In gold and grey text, \"MEDIEVAL MINECRAFT\" is displayed infront of a screenshot of the Minecraft Overworld. The background image has a tree with purple leaves on both sides.](https://cdn.modrinth.com/data/cached_images/bed0adec645cc7795ce93fd9e796f505e14646fb.jpeg)\n\n![In all-caps bold text, the word \"FEATURES\". ](https://cdn.modrinth.com/data/cached_images/785d3640a720d7e56cba3a6e2bbcdc37f34cf7e1.png)\n\n⚔️ Full parity with [Curseforge Version](https://legacy.curseforge.com/minecraft/modpacks/medieval-mc-mmc4)\n\n⚔️ Completely Overhauled World Generation ([Biomes o' Plenty](https://modrinth.com/mod/biomes-o-plenty), [Geophilic](https://modrinth.com/datapack/geophilic), [Ecologics](https://modrinth.com/mod/ecologics))\n\n⚔️ Thousands of NEW Dungeons & Structures ([Wabi-Sabi Structures](https://modrinth.com/datapack/wabi-sabi-structures), [When Dungeons Arise](https://modrinth.com/mod/when-dungeons-arise), [Towns and Towers](https://modrinth.com/mod/towns-and-towers))\n\n⚔️ Grow Your Own Kingdom ([Minecolonies](https://modrinth.com/mod/minecolonies), [Stylecolonies](https://www.curseforge.com/minecraft/mc-mods/stylecolonies))\n\n⚔️ Explore Magical Dimensions ([The Twilight Forest](https://www.curseforge.com/minecraft/mc-mods/the-twilight-forest), [The Aether](https://modrinth.com/mod/aether) & Addons, [BetterEnd](https://modrinth.com/mod/betterend))\n\n⚔️ Fully Optimized with Shader Support\n\n⚔️ Overhauled Stronghold & Fortresses\n\n⚔️ Powerful Bosses and Mythical Creatures ([L_Ender's Cataclysm](https://modrinth.com/mod/l_enders-cataclysm), [Ice and Fire: Dragons](https://modrinth.com/mod/ice-and-fire-dragons))\n\n⚔️ In-depth Magic Mods ([Iron's Spells 'n Spellbooks ](https://modrinth.com/mod/irons-spells-n-spellbooks), [Ars Nouveau](https://modrinth.com/mod/ars-nouveau/), [Eidolon: Repraised](https://modrinth.com/mod/eidolonrepraised), [Wizard's Reborn](https://modrinth.com/mod/wizards-reborn))\n\n⚔️ Stamina, Thirst and Temperature System ([Survive](https://modrinth.com/mod/survive))\n\n⚔️ Simple Quests to Guide You\n\n⚔️ QoL Features such as [Waystones](https://modrinth.com/mod/waystones) and [Upgradeable Backpacks](https://modrinth.com/mod/travelersbackpack)\n\n⚔️ An Immersive Medieval RPG Experience\n\n⚔️ Built-in, [Free World Sharing](https://www.youtube.com/watch?v=tLTC6wYcWVM)\n\n⚔️ [350+ Mods](https://www.modpackindex.com/modpack/64101/medieval-mc-forge-mmc4), heavily customized for integration and compatibility\n\n[![Live count of how many members are online in the Luna Pixel Studios discord server.](https://img.shields.io/discord/790272037578473512?label=Discord&color=393939&labelColor=0843bf&style=for-the-badge&logo=discord&logoColor=white)](https://lunapixel.studio/discord)\n[![Use code LUNAPIXEL for 25% off Bisect Hosting](https://cdn.modrinth.com/data/cached_images/2c3d1af34a17cb45f2ba4b9cfca4bd54d1c857ef.png)](https://lunapixel.studio/bisect)\n\n\u003Ciframe width=\"560\" height=\"315\" src=\"https://www.youtube-nocookie.com/embed/dFd3YVpPFe0\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen>\u003C/iframe>\n\n\u003Ciframe width=\"560\" height=\"315\" src=\"https://www.youtube-nocookie.com/embed/ENqdTyHdkVo\" title=\"YouTube video player\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" allowfullscreen>\u003C/iframe>\n\n\nNOT AN OFFICIAL MINECRAFT PRODUCT. NOT APPROVED BY OR ASSOCIATED WITH MOJANG OR MICROSOFT","2023-07-19T10:47:40.633768Z","2025-02-08T21:00:52.290353Z","2023-11-21T03:01:24.307956Z","2023-11-17T17:39:15.947716Z",{"id":30051,"name":10,"url":3592},150570,187,[30,77,171],[69,162,200,211],[354],[33398,33399,33400,33401,33402,33403],"BUIdPqku","ANsx3jH0","43Yh3aDW","1JucqU8S","X2LLLIx2","UwCGH2RP","https://cdn.modrinth.com/data/cad6ZNtm/58091d927baf593d482cd7ee738875c78fadf69e_96.webp","https://discord.gg/LunaPixel","https://github.com/LunaPixelStudios/Medieval-MC/wiki",[33408],{"id":3149,"platform":3150,"url":33409},"https://ko-fi.com/shxrkie",[33411],{"url":33412,"raw_url":33413,"featured":849,"title":33414,"description":3592,"created":33415,"ordering":30075},"https://cdn.modrinth.com/data/cad6ZNtm/images/ff93b9a914325c465bb8c03cb3264877b7e5f5c1